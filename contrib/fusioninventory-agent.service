[Unit]
Description=Go FusionInventory Agent (inventory run)
Documentation=https://github.com/jniltinho/go-fusioninventory-agent
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
# `run` does a single inventory cycle (server or local, per agent.cfg).
# Scheduling is handled by the companion .timer.
ExecStart=/usr/bin/fusioninventory-agent run --conf-file /etc/fusioninventory/agent.cfg
# runs as root to read dmidecode, /sys/class/dmi and disk serials
User=root

[Install]
WantedBy=multi-user.target
